{
  "expo": {
    "name": "Prooof",
    "slug": "prooof-native",
    "version": "1.0.0",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/00000000-0000-0000-0000-000000000000"
    },
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "scheme": "prooof",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "buildNumber": "1",
      "supportsTablet": true,
      "bundleIdentifier": "com.prooof.native",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "versionCode": 1,
      "package": "com.prooof.app",
      "permissions": [
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.WAKE_LOCK"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "single"
    },
    "plugins": [
      "expo-background-fetch",
      "expo-task-manager",
      [
        "@stripe/stripe-react-native",
        {
          "merchantIdentifier": "merchant.com.prooof.app"
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "1768809d-de2e-450c-8fec-c53f4f928fe6"
      }
    },
    "owner": "rhysgriffin47"
  }
}
