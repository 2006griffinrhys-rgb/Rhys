EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
EXPO_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-anon-key
EXPO_PUBLIC_SUPABASE_PROJECT_ID=your-project-ref
EXPO_PUBLIC_SUPPORT_URL=https://www.prooof.app
EXPO_PUBLIC_STRIPE_BILLING_ENABLED=false
EXPO_PUBLIC_STRIPE_PORTAL_URL=
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=
EXPO_PUBLIC_STRIPE_MERCHANT_IDENTIFIER=merchant.com.prooof.native
EXPO_PUBLIC_AUTO_INBOX_SCAN_ENABLED=true
EXPO_PUBLIC_AUTO_INBOX_SCAN_INTERVAL_SECONDS=120
EXPO_PUBLIC_BACKGROUND_INBOX_TASK_ENABLED=true
EXPO_PUBLIC_BACKGROUND_INBOX_TASK_INTERVAL_SECONDS=900
EXPO_PUBLIC_SERVER_SCAN_FALLBACK_ENABLED=true

# Server-side claim email delivery (Supabase Edge Function secrets)
# Set these in Supabase secrets (recommended), not in client app env:
# RESEND_API_KEY=
# CLAIM_EMAIL_FROM=claims@yourdomain.com
# CLAIM_EMAIL_REPLY_TO=support@yourdomain.com
